{
  // 1. Kills the popup menu completely
  "editor.quickSuggestions": {
    "other": "off",
    "comments": "off",
    "strings": "off"
  },
  
  // 2. Kills "Ghost Text" (Inline/AI suggestions like Copilot)
  "editor.inlineSuggest.enabled": false,

  // 3. Kills the hovering box when you mouse over code
  "editor.hover.enabled": false,

  // 4. Kills the parameter hints (the "how to use this function" popup)
  "editor.parameterHints.enabled": false,

  // 5. Stops VS Code from suggesting words it finds in your file
  "editor.wordBasedSuggestions": "off",

  // 6. Prevents suggestions from popping up when you type "." or "("
  "editor.suggestOnTriggerCharacters": false,

  // 7. If you have GitHub Copilot, this shuts it up specifically
  "github.copilot.enable": {
    "*": false
  }
}